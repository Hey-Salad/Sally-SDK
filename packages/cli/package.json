{
  "name": "@heysalad/sally",
  "version": "0.1.0",
  "description": "HeySalad Sally command line interface.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/Hey-Salad/sally#readme",
  "bugs": {
    "url": "https://github.com/Hey-Salad/sally/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hey-Salad/sally.git"
  },
  "keywords": [
    "heysalad",
    "sally",
    "cli",
    "cloudflare",
    "device-automation",
    "ios",
    "android"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "preferGlobal": true,
  "bin": {
    "sally": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@heysalad/sally-sdk": "workspace:*",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.6",
    "vitest": "^3.2.4"
  }
}
