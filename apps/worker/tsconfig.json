{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "WebWorker"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": [
      "@cloudflare/workers-types"
    ],
    "rootDir": "src",
    "outDir": "dist",
    "noEmit": true
  },
  "include": [
    "src/**/*.ts"
  ]
}

