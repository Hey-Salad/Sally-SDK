{
  "name": "@heysalad/sally-worker",
  "version": "0.0.0",
  "private": true,
  "description": "Cloudflare Worker control plane for Sally.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:migrate:local": "wrangler d1 migrations apply heysalad-sally --local",
    "db:migrate:remote": "wrangler d1 migrations apply heysalad-sally --remote",
    "deploy": "wrangler deploy",
    "deploy:dry-run": "wrangler deploy --dry-run",
    "dev": "wrangler dev",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "hono": "^4.9.8",
    "jose": "^6.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260313.0",
    "@types/node": "^24.5.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.56.0"
  }
}
